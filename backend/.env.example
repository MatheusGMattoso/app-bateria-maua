PORT=3000
SUPABASE_URL=
SUPABASE_KEY=

# service_role key (Supabase > Project Settings > API > service_role / secret).
# Usada apenas no backend para o upload de imagens do mural ao Storage.
# NUNCA exponha esta chave no app/cliente.
SUPABASE_SERVICE_KEY=

# Connection string (Supabase > Project Settings > Database > URI)
# Necessario para criar tabelas via: npm run db:setup-eventos
DATABASE_URL=

# Segredo usado para assinar/verificar os tokens JWT de login.
# Use um valor longo e aleatorio (ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=